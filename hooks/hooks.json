{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash.*setup\\.sh",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-install.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/check_daemon.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
